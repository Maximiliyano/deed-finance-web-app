{
  "AllowedHosts": "*",
  "DatabaseConnection": "",
  "WebUrlSettings": {
    "UIUrl": "",
    "ExchangeRatesPrivatAPIUrl": "https://api.privatbank.ua/p24api/exchange_rates?json&date={0}"
  },
  "AuthSettings": {
    "Domain": "",
    "ClientID": "",
    "ClientSecret": ""
  },
  "BackgroundJobsSettings": {
    "CronExchangeSchedule": "0 0 9 * * ?",
    "CronReminderCheckSchedule": "0 0/15 * * * ?"
  },
  "SmtpSettings": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": ""
  },
  "MemoryCacheSettings": {
    "ExchangesTimespanInHours": 12,
    "CategoriesTimespanInHours": 1 
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
